[0.004, "o", "\u001b[1;1H\u001b[38;5;130m  1 \u001b[m\u001b[34m#!/usr/bin/env python3\u001b[m\r\n\u001b[38;5;130m  2 \u001b[m\u001b[31m\"\"\"交互式 agent demo。\u001b[m\u001b[2;27H\u001b[K\u001b[3;1H\u001b[38;5;130m  3 \u001b[m\u001b[3;5H\u001b[K\u001b[4;1H\u001b[38;5;130m  4 \u001b[m\u001b[31mpip install pytspclient openai\u001b[m\r\n\u001b[38;5;130m  5 \u001b[m\u001b[31mexport OPENAI_API_KEY\u001b[m\r\n\u001b[38;5;130m  6 \u001b[m\u001b[31mpython examples/demo_agent.py\u001b[m\r\n\u001b[38;5;130m  7 \u001b[m\u001b[31m\"\"\"\u001b[m\r\n\u001b[38;5;130m  8 \r\n  9 \u001b[m\u001b[35mimport\u001b[m asyncio\r\n\u001b[38;5;130m 10 \u001b[m\u001b[35mfrom\u001b[m pytspclient \u001b[35mimport\u001b[m TSPClient\r\n\u001b[38;5;130m 11 \u001b[m\u001b[35mfrom\u001b[m openai \u001b[35mimport\u001b[m OpenAI\r\n\u001b[38;5;130m 12 \r\n 13 \u001b[mGTSP_PATH = \u001b[31m\"./gtsp-darwin-amd64\"\u001b[m  \u001b[34m# 替换为实际路径\u001b[m\r\n\u001b[38;5;130m 14 \r\n 15 async\u001b[m \u001b[38;5;130mdef\u001b[m \u001b[36mmain\u001b[m():\r\n\u001b[38;5;130m 16 \u001b[m    tsp = \u001b[38;5;130mawait\u001b[m TSPClient.from_stdio(GTSP_PATH).start()\r\n\u001b[38;5;130m 17 \u001b[m    adapter = tsp.for_openai()\r\n\u001b[38;5;130m 18 \u001b[m    llm = OpenAI()\r\n\u001b[38;5;130m 19 \u001b[m    messages = [{\u001b[31m\"role\"\u001b[m: \u001b[31m\"system\"\u001b[m, \u001b[31m\"content\"\u001b[m: \u001b[31m\"You are a helpful assistant.\"\u001b[m}]\r\n\u001b[38;5;130m 20 \r\n 21 \u001b"]
[0.000, "o", "[m    \u001b[34m# 循环获取用户任务\u001b[m\r\n\u001b[38;5;130m 22 \u001b[m    \u001b[38;5;130mwhile\u001b[m \u001b[36mTrue\u001b[m:\r\n\u001b[38;5;130m 23 \u001b[m\u001b[8Ccontent = \u001b[36minput\u001b[m(\u001b[31m\"\u001b[m\u001b[35m\\033\u001b[m\u001b[31m[1mYou:\u001b[m\u001b[35m\\033\u001b[m\u001b[31m[0m \"\u001b[m).strip() \u001b[34m# 加粗 \"You:\"\u001b[m\r\n\u001b[38;5;130m 24 \u001b[8Cif\u001b[m \u001b[38;5;130mnot\u001b[m content: \u001b[38;5;130mcontinue\r\n 25 \u001b[m\u001b[8Cmessages.append({\u001b[31m\"role\"\u001b[m: \u001b[31m\"user\"\u001b[m, \u001b[31m\"content\"\u001b[m: content})\r\n\u001b[38;5;130m 26 \r\n 27 \u001b[m\u001b[8C\u001b[34m# ----- 以下10代码，即可实现 agent 自主连续行动，直到完成用户任务 -----\u001b[m\r\n\u001b[38;5;130m 28 \u001b[8Cwhile\u001b[m \u001b[36mTrue\u001b[m:\r\n\u001b[38;5;130m 29 \u001b[m\u001b[12Cresp = llm.chat.completions.create(model=\u001b[31m\"glm-5\"\u001b[m, messages=messages, tools=adapter.tools)\r\n\u001b[38;5;130m 30 \u001b[m\u001b[12Cmessages.append(resp.choices[\u001b[31m0\u001b[m].message)\r\n\u001b[38;5;130m 31 \r\n 32 \u001b[m\u001b[12Ccalls = adapter.parse_tool_calls(resp)\r\n\u001b[38;5;130m 33 \u001b[12Cif\u001b[m calls:\r\n\u001b[38;5;130m 34 \u001b[m\u001b[16Cresults = \u001b[38;5;130mawait\u001b[m adapter.execute_tool_calls(resp)\r\n"]
[0.001, "o", "\u001b[38;5;130m 35 \u001b[m\u001b[16Cmessages.extend(adapter.to_tool_messages(results))\r\n\u001b[38;5;130m 36 \u001b[12Celse\u001b[m:\r\n\u001b[38;5;130m 37 \u001b[m\u001b[16C\u001b[36mprint\u001b[m(\u001b[31mf\"\u001b[m\u001b[35m\\n\\033\u001b[m\u001b[31m[100;97m Agent: \u001b[m\u001b[35m{\u001b[mresp.choices[\u001b[31m0\u001b[m].message.content\u001b[35m}\u001b[m\u001b[31m \u001b[m\u001b[35m\\033\u001b[m\u001b[31m[0m\u001b[m\u001b[35m\\n\u001b[m\u001b[31m\"\u001b[m)\r\n\u001b[38;5;130m 38 \u001b[16Cbreak\r\n 39 \r\n 40 \u001b[masyncio.run(main())\r\n\u001b[94m~                                                                                                                                    \u001b[42;1H~                                                                                                                                    \u001b[43;1H~                                                                                                                                    \u001b[44;1H~                                                                                                                                    \u001b[1;5H\u001b[?25h\u001b[?u\u001b[?12$p"]
[0.004, "o", "\u001b[27m\u001b[23m\u001b[29m\u001b[m\u001b[H\u001b[2J\u001b[?25l\u001b[1;1H\u001b[93m  1 \u001b[m\u001b[96m#!/usr/bin/env python3\u001b[m\r\n\u001b[93m  2 \u001b[m\u001b[95m\"\"\"交互式 agent demo。\u001b[m\r\n\u001b[93m  3 \r\n  4 \u001b[m\u001b[95mpip install pytspclient openai\u001b[m\r\n\u001b[93m  5 \u001b[m\u001b[95mexport OPENAI_API_KEY\u001b[m\r\n\u001b[93m  6 \u001b[m\u001b[95mpython examples/demo_agent.py\u001b[m\r\n\u001b[93m  7 \u001b[m\u001b[95m\"\"\"\u001b[m\r\n\u001b[93m  8 \r\n  9 \u001b[m\u001b[38;5;81mimport\u001b[m asyncio\r\n\u001b[93m 10 \u001b[m\u001b[38;5;81mfrom\u001b[m pytspclient \u001b[38;5;81mimport\u001b[m TSPClient\r\n\u001b[93m 11 \u001b[m\u001b[38;5;81mfrom\u001b[m openai \u001b[38;5;81mimport\u001b[m OpenAI\r\n\u001b[93m 12 \r\n 13 \u001b[mGTSP_PATH = \u001b[95m\"./gtsp-darwin-amd64\"\u001b[m  \u001b[96m# 替换为实际路径\u001b[m\r\n\u001b[93m 14 \r\n 15 \u001b[m\u001b[93masync\u001b[m \u001b[93mdef\u001b[m \u001b[1m\u001b[96mmain\u001b[m():\r\n\u001b[93m 16 \u001b[m    tsp = \u001b[93mawait\u001b[m TSPClient.from_stdio(GTSP_PATH).start()\r\n\u001b[93m 17 \u001b[m    adapter = tsp.for_openai()\r\n\u001b[93m 18 \u001b[m    llm = OpenAI()\r\n\u001b[93m 19 \u001b[m    messages = [{\u001b[95m\"role\"\u001b[m: \u001b[95m\"system\"\u001b[m, \u001b[95m\"content\"\u001b[m: \u001b[95m\"You are a helpful assistant.\"\u001b[m}]\r\n\u001b[93m 20 \r\n 21 \u001b[m    \u001b[96m# 循环获取用户任务\u001b[m\r\n\u001b[93m 22 \u001b[m    \u001b[93mwhile\u001b[m \u001b[1m\u001b[96m"]
[0.000, "o", "True\u001b[m:\r\n\u001b[93m 23 \u001b[m\u001b[8Ccontent = \u001b[1m\u001b[96minput\u001b[m(\u001b[95m\"\u001b[m\u001b[38;5;224m\\033\u001b[m\u001b[95m[1mYou:\u001b[m\u001b[38;5;224m\\033\u001b[m\u001b[95m[0m \"\u001b[m).strip() \u001b[96m# 加粗 \"You:\"\u001b[m\r\n\u001b[93m 24 \u001b[m\u001b[8C\u001b[93mif\u001b[m \u001b[93mnot\u001b[m content: \u001b[93mcontinue\u001b[m\r\n\u001b[93m 25 \u001b[m\u001b[8Cmessages.append({\u001b[95m\"role\"\u001b[m: \u001b[95m\"user\"\u001b[m, \u001b[95m\"content\"\u001b[m: content})\r\n\u001b[93m 26 \r\n 27 \u001b[m\u001b[8C\u001b[96m# ----- 以下10代码，即可实现 agent 自主连续行动，直到完成用户任务 -----\u001b[m\r\n\u001b[93m 28 \u001b[m\u001b[8C\u001b[93mwhile\u001b[m \u001b[1m\u001b[96mTrue\u001b[m:\r\n\u001b[93m 29 \u001b[m\u001b[12Cresp = llm.chat.completions.create(model=\u001b[95m\"glm-5\"\u001b[m, messages=messages, tools=adapter.tools)\r\n\u001b[93m 30 \u001b[m\u001b[12Cmessages.append(resp.choices[\u001b[95m0\u001b[m].message)\r\n\u001b[93m 31 \r\n 32 \u001b[m\u001b[12Ccalls = adapter.parse_tool_calls(resp)\r\n\u001b[93m 33 \u001b[m\u001b[12C\u001b[93mif\u001b[m calls:\r\n\u001b[93m 34 \u001b[m\u001b[16Cresults = \u001b[93mawait\u001b[m adapter.execute_tool_calls(resp)\r\n\u001b[93m 35 \u001b[m\u001b[16Cmessages.extend(adapter.to_tool_messages(results))\r\n\u001b[93m 36 \u001b[m\u001b[12C\u001b[93melse"]
[0.001, "o", "\u001b[m:\r\n\u001b[93m 37 \u001b[m\u001b[16C\u001b[1m\u001b[96mprint\u001b[m(\u001b[95mf\"\u001b[m\u001b[38;5;224m\\n\\033\u001b[m\u001b[95m[100;97m Agent: \u001b[m\u001b[38;5;224m{\u001b[mresp.choices[\u001b[95m0\u001b[m].message.content\u001b[38;5;224m}\u001b[m\u001b[95m \u001b[m\u001b[38;5;224m\\033\u001b[m\u001b[95m[0m\u001b[m\u001b[38;5;224m\\n\u001b[m\u001b[95m\"\u001b[m)\r\n\u001b[93m 38 \u001b[m\u001b[16C\u001b[93mbreak\u001b[m\r\n\u001b[93m 39 \r\n 40 \u001b[masyncio.run(main())\r\n\u001b[94m~                                                                                                                                    \u001b[42;1H~                                                                                                                                    \u001b[43;1H~                                                                                                                                    \u001b[44;1H~                                                                                                                                    \u001b[m\u001b[45;1H\"demo_agent.py\" 40L, 1331B\u001b[1;5H\u001b[?25h"]
